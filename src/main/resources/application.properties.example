spring.application.name=slackwise

# Slack
slack.bot.token=${SLACK_BOT_TOKEN:}
slack.channel.id=${SLACK_CHANNEL_ID:}
slack.client.id=${SLACK_CLIENT_ID:}
slack.client.secret=${SLACK_CLIENT_SECRET:}
slack.signing.secret=${SLACK_SIGNING_SECRET:}
slack.oauth.redirect.uri=${SLACK_OAUTH_REDIRECT_URI:}
slack.oauth.bot.scopes=${SLACK_OAUTH_BOT_SCOPES:chat:write,channels:read,channels:history,groups:history,commands,users:read}
slack.oauth.user.scopes=${SLACK_OAUTH_USER_SCOPES:}

# ConnectWise
company.id=${COMPANY_ID:}
company.idnumber=${COMPANY_ID_NUMBER:}
public.key=${CONNECTWISE_PUBLIC_KEY:}
private.key=${CONNECTWISE_PRIVATE_KEY:}
client.id=${CONNECTWISE_CLIENT_ID:}

# AWS / DynamoDB
aws.region=${AWS_REGION:us-east-2}
aws.dynamodb.table=${AWS_DYNAMODB_TABLE:}
aws.accessKeyId=${AWS_ACCESS_KEY_ID:}
aws.secretAccessKey=${AWS_SECRET_ACCESS_KEY:}

# Assignment defaults
lead.contact.name=${LEAD_CONTACT_NAME:}
user.id=${DEFAULT_USER_ID:0}
user.identifier=${DEFAULT_USER_IDENTIFIER:}

# App Auth
app.auth.enabled=${APP_AUTH_ENABLED:false}
app.auth.tenant-claims=${APP_AUTH_TENANT_CLAIMS:tenant_id,tenantId,company_id,org_id}
spring.security.oauth2.resourceserver.jwt.issuer-uri=${OAUTH_ISSUER_URI:}
spring.security.oauth2.resourceserver.jwt.audiences=${OAUTH_AUDIENCE:}

# Security Controls
security.audit.enabled=${SECURITY_AUDIT_ENABLED:true}
security.audit.persist.enabled=${SECURITY_AUDIT_PERSIST_ENABLED:true}
security.audit.retention-days=${SECURITY_AUDIT_RETENTION_DAYS:30}
security.rate-limit.enabled=${SECURITY_RATE_LIMIT_ENABLED:true}
security.rate-limit.per-tenant.enabled=${SECURITY_RATE_LIMIT_PER_TENANT_ENABLED:true}
security.rate-limit.window-seconds=${SECURITY_RATE_LIMIT_WINDOW_SECONDS:60}
security.rate-limit.webhook-max-requests=${SECURITY_RATE_LIMIT_WEBHOOK_MAX_REQUESTS:120}
security.rate-limit.auth-max-requests=${SECURITY_RATE_LIMIT_AUTH_MAX_REQUESTS:30}
